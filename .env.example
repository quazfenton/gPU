# =============================================================================
# Notebook ML Orchestrator - Environment Configuration Example
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control (it's in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# CORE APPLICATION SETTINGS
# -----------------------------------------------------------------------------

# Application name and environment
APP_NAME=Notebook ML Orchestrator
APP_ENV=development  # development, staging, production
DEBUG=false

# Database configuration
ORCHESTRATOR_DB_PATH=orchestrator.db
# For production: ORCHESTRATOR_DB_PATH=/var/lib/orchestrator/orchestrator.db

# Logging configuration
ORCHESTRATOR_LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
ORCHESTRATOR_LOG_FILE=orchestrator.log
# For production: ORCHESTRATOR_LOG_FILE=/var/log/orchestrator/orchestrator.log

# -----------------------------------------------------------------------------
# SECURITY SETTINGS (REQUIRED FOR PRODUCTION)
# -----------------------------------------------------------------------------

# Master encryption key for credential store (32+ bytes recommended)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
MASTER_KEY=your-master-key-at-least-32-bytes-long-change-in-production

# JWT secret key for token signing (32+ bytes recommended)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-jwt-secret-at-least-32-bytes-long-change-in-production

# Salt for credential key derivation (64 hex characters = 32 bytes)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CREDENTIAL_SALT=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Security feature toggles
GUI_ENABLE_AUTH=false  # Set to true to enable authentication
GUI_ENABLE_RATE_LIMITING=true
GUI_RATE_LIMIT_PER_MINUTE=60
GUI_RATE_LIMIT_PER_HOUR=1000

# Session configuration
GUI_SESSION_TIMEOUT=3600  # Session timeout in seconds (default: 1 hour)

# Two-factor authentication
ENABLE_2FA=false  # Set to true to enable TOTP 2FA

# Password policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=false

# Brute force protection
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# -----------------------------------------------------------------------------
# BACKEND CREDENTIALS (Store in CredentialStore for production)
# -----------------------------------------------------------------------------

# Modal.com credentials
# MODAL_TOKEN_ID=your-modal-token-id
# MODAL_TOKEN_SECRET=your-modal-token-secret

# HuggingFace credentials
# HF_TOKEN=your-huggingface-token

# Kaggle credentials
# KAGGLE_USERNAME=your-kaggle-username
# KAGGLE_KEY=your-kaggle-api-key

# Google Colab credentials (for OAuth)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# AWS credentials (for AWS backend or Secrets Manager)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1

# Azure credentials (for Azure backend or Key Vault)
# AZURE_CLIENT_ID=your-azure-client-id
# AZURE_CLIENT_SECRET=your-azure-client-secret
# AZURE_TENANT_ID=your-azure-tenant-id
# AZURE_SUBSCRIPTION_ID=your-azure-subscription-id

# -----------------------------------------------------------------------------
# SECRETS MANAGER INTEGRATION (Optional - for production)
# -----------------------------------------------------------------------------

# HashiCorp Vault
# VAULT_URL=https://vault.example.com
# VAULT_TOKEN=your-vault-token
# VAULT_PATH=secret/orchestrator

# AWS Secrets Manager
# AWS_SECRETS_MANAGER_ENABLED=false
# AWS_SECRET_NAME=orchestrator/master-key

# Azure Key Vault
# AZURE_KEY_VAULT_ENABLED=false
# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/

# -----------------------------------------------------------------------------
# GUI CONFIGURATION
# -----------------------------------------------------------------------------

# Server configuration
GUI_HOST=0.0.0.0
GUI_PORT=7860
GUI_WEBSOCKET_PORT=7861

# Theme configuration
GUI_THEME=default  # default, soft, monochrome

# Page configuration
GUI_PAGE_SIZE=50
GUI_AUTO_REFRESH_INTERVAL=5  # seconds

# File uploads
GUI_UPLOAD_DIR=uploads
GUI_MAX_UPLOAD_SIZE=104857600  # 100MB in bytes

# WebSocket configuration
GUI_ENABLE_WEBSOCKET=true

# Public sharing (Gradio share)
GUI_SHARE=false

# -----------------------------------------------------------------------------
# OAUTH 2.0 PROVIDERS (Optional - for social login)
# -----------------------------------------------------------------------------

# Google OAuth
# OAUTH_GOOGLE_ENABLED=false
# OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
# OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
# OAUTH_GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# GitHub OAuth
# OAUTH_GITHUB_ENABLED=false
# OAUTH_GITHUB_CLIENT_ID=your-github-client-id
# OAUTH_GITHUB_CLIENT_SECRET=your-github-client-secret
# OAUTH_GITHUB_REDIRECT_URI=https://your-domain.com/auth/github/callback

# Azure AD OAuth
# OAUTH_AZURE_ENABLED=false
# OAUTH_AZURE_CLIENT_ID=your-azure-client-id
# OAUTH_AZURE_CLIENT_SECRET=your-azure-client-secret
# OAUTH_AZURE_TENANT_ID=your-azure-tenant-id
# OAUTH_AZURE_REDIRECT_URI=https://your-domain.com/auth/azure/callback

# -----------------------------------------------------------------------------
# SECURITY LOGGING & MONITORING
# -----------------------------------------------------------------------------

# Security log file
SECURITY_LOG_FILE=security.log
# For production: SECURITY_LOG_FILE=/var/log/orchestrator/security.log

# Security log level
SECURITY_LOG_LEVEL=INFO

# Webhook alerts for critical events (Slack, Teams, etc.)
# SECURITY_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# SECURITY_WEBHOOK_EVENTS=security.sql_injection,security.xss,session.hijack_attempt

# Log retention
SECURITY_LOG_RETENTION_DAYS=90
SECURITY_LOG_MAX_EVENTS=100000

# SIEM integration (optional)
# SIEM_ENABLED=false
# SIEM_ENDPOINT=https://your-siem.example.com/api/events
# SIEM_API_KEY=your-siem-api-key

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------

# Global rate limits
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# Rate limit by endpoint
# RATE_LIMIT_API_PER_MINUTE=100
# RATE_LIMIT_AUTH_PER_MINUTE=10
# RATE_LIMIT_UPLOAD_PER_MINUTE=20

# -----------------------------------------------------------------------------
# BACKEND ROUTING
# -----------------------------------------------------------------------------

# Default routing strategy
ROUTING_STRATEGY=cost-optimized  # cost-optimized, round-robin, least-loaded

# Backend preferences
PREFER_FREE_TIER=true

# Health check configuration
HEALTH_CHECK_INTERVAL=300  # seconds
HEALTH_CHECK_TIMEOUT=30  # seconds

# Retry configuration
MAX_RETRIES=3
RETRY_BACKOFF_BASE=2  # exponential backoff multiplier

# -----------------------------------------------------------------------------
# WORKFLOW ENGINE
# -----------------------------------------------------------------------------

# Workflow configuration
WORKFLOW_MAX_STEPS=50
WORKFLOW_TIMEOUT=3600  # seconds
WORKFLOW_MAX_CONCURRENT=10

# -----------------------------------------------------------------------------
# BATCH PROCESSING
# -----------------------------------------------------------------------------

# Batch configuration
BATCH_MAX_ITEMS=1000
BATCH_MAX_PARALLEL=10
BATCH_TIMEOUT=7200  # seconds

# -----------------------------------------------------------------------------
# FILE STORAGE
# -----------------------------------------------------------------------------

# Upload directory
UPLOAD_DIR=uploads

# Maximum file size
MAX_FILE_SIZE=104857600  # 100MB

# Allowed file types
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,mp3,wav,mp4,avi,pdf,txt,csv,json

# Cloud storage (optional)
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-s3-access-key
# S3_SECRET_KEY=your-s3-secret-key

# -----------------------------------------------------------------------------
# EMAIL NOTIFICATIONS (Optional)
# -----------------------------------------------------------------------------

# SMTP configuration
# SMTP_ENABLED=false
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM_EMAIL=noreply@example.com

# Email notifications
# NOTIFY_ON_JOB_COMPLETE=false
# NOTIFY_ON_JOB_FAILED=false
# NOTIFY_ON_SECURITY_ALERT=true

# -----------------------------------------------------------------------------
# METRICS & MONITORING
# -----------------------------------------------------------------------------

# Prometheus metrics
# PROMETHEUS_ENABLED=false
# PROMETHEUS_PORT=9090

# Health check endpoint
HEALTH_CHECK_ENDPOINT=/health

# -----------------------------------------------------------------------------
# ADVANCED SETTINGS (Usually don't need to change)
# -----------------------------------------------------------------------------

# Encryption settings
ENCRYPTION_ALGORITHM=AES-256-GCM
PBKDF2_ITERATIONS=100000

# Token settings
ACCESS_TOKEN_EXPIRY_MINUTES=30
REFRESH_TOKEN_EXPIRY_DAYS=7

# Session settings
MAX_CONCURRENT_SESSIONS=5

# Database connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# -----------------------------------------------------------------------------
# DEVELOPMENT SETTINGS (Only for local development)
# -----------------------------------------------------------------------------

# Enable debug mode (NEVER in production)
# DEBUG=true

# Enable test credentials (NEVER in production)
# TEST_MODE=false

# Enable verbose logging
# VERBOSE_LOGGING=false

# Enable hot reload
# HOT_RELOAD=true

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
